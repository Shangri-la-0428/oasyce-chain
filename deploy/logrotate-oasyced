# /etc/logrotate.d/oasyced
# Install: cp deploy/logrotate-oasyced /etc/logrotate.d/oasyced
# Test:    logrotate -d /etc/logrotate.d/oasyced

/var/log/oasyced.log
/var/log/oasyced/*.log
/var/log/oasyce-alert.log
/var/log/oasyce-econ.log
{
    daily
    rotate 7
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
    maxsize 50M
    create 0640 oasyce oasyce
}
